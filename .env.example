# SynapseGrid 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# 安全配置（生产环境必须修改）
# ============================================

# 运行环境：development 或 production
# production 时启用 HTTPS 强制重定向
ENVIRONMENT=development

# HMAC 密钥：用于内容签名和完整性验证
# 必须至少 32 字节，生产环境请使用安全的随机字符串
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SYNAPSEGRID_HMAC_KEY=dev-only-change-me-must-be-32-bytes

# CORS 允许的来源（逗号分隔）
# 生产环境请设置为实际的前端域名
# 例如：SYNAPSEGRID_CORS_ORIGINS=https://app.example.com,https://admin.example.com
SYNAPSEGRID_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# 后端配置
# ============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ============================================
# 前端配置
# ============================================
VITE_API_BASE=http://localhost:8000/api/v1

# ============================================
# LLM API 密钥（可选，可在前端界面配置）
# ============================================
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
